# ============================================================
# Autonomous Scientific Discovery Engine - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# LLM Provider Configuration
# ============================================================

# Choose your LLM provider: "openai" or "ollama"
LLM_PROVIDER=openai

# --- OpenAI (cloud, requires API key) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Ollama (local, free, no API key needed) ---
# Install Ollama: https://ollama.ai
# Run: ollama pull llama3 (or mistral, gemma, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================================
# Paper Ingestion Sources
# ============================================================

# ArXiv (no API key required - free public API)
ARXIV_MAX_RESULTS=20

# PubMed / NCBI (optional: add API key for higher rate limits)
# Get key at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
PUBMED_MAX_RESULTS=20

# Semantic Scholar (optional, for citation graph)
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Vector Database (for paper embeddings)
# ============================================================

# ChromaDB (local, no setup needed)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=scientific_papers

# ============================================================
# Discovery Engine Settings
# ============================================================

# Default scientific domain (oncology, genetics, neuroscience, etc.)
DEFAULT_DOMAIN=general

# Number of hypotheses to generate per run
MAX_HYPOTHESES=5

# Minimum confidence score for a hypothesis to be included (0.0-1.0)
MIN_CONFIDENCE_THRESHOLD=0.6

# Maximum papers to fetch per discovery run
MAX_PAPERS_PER_RUN=20

# ============================================================
# Knowledge Graph Settings
# ============================================================

# Graph storage directory
GRAPH_PERSIST_DIR=./knowledge_graphs

# Minimum edge weight to consider a relationship significant
GRAPH_MIN_EDGE_WEIGHT=0.3

# ============================================================
# Output & Logging
# ============================================================

# Output directory for discovery reports
OUTPUT_DIR=./outputs

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================
# Streamlit App Settings
# ============================================================

STREAMLIT_SERVER_PORT=8501
STREAMLIT_THEME=dark
